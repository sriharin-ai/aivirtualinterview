modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "3000"
AI_SERVICE_PORT = "8000"
OLLAMA_MODEL_NAME = "mistral"
VITE_API_URL = "/api"
VITE_GOOGLE_CLIENT_ID = ""
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "Admin@2024"
SMTP_HOST = "smtp.resend.com"
SMTP_PORT = "465"
SMTP_USER = "resend"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Service"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && node server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "AI Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ai-service && python main.py"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd backend && node server.js & cd ai-service && python main.py & cd frontend && npm run build && npx serve -s dist -l 5000"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
